{
  "name": "collab-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"web,server\" --prefix-colors \"cyan,yellow\" \"next dev\" \"npm run dev:server\"",
    "dev:web": "next dev",
    "dev:server": "cd apps/server && npm install --silent && npx ts-node index.ts",
    "build": "next build",
    "build:server": "cd apps/server && npm install --silent && npx tsc",
    "start": "concurrently --names \"web,server\" --prefix-colors \"cyan,yellow\" \"next start\" \"node apps/server/dist/index.js\"",
    "start:web": "next start",
    "start:server": "node apps/server/dist/index.js",
    "lint": "next lint"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.5",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.104.1",
    "concurrently": "^8.2.2",
    "date-fns": "^4.1.0",
    "fabric": "^7.2.0",
    "nanoid": "^5.1.9",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "y-monaco": "^0.1.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "monaco-editor": "^0.55.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
